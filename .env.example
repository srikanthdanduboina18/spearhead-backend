# Copy to .env and fill in.

PORT=4000
NODE_ENV=development

# Postgres — e.g. AWS RDS (Mumbai) or Supabase (ap-south-1) for data residency.
DATABASE_URL="postgresql://user:password@localhost:5432/spearhead_eb"

# Long random string — used to sign session JWTs.
JWT_SECRET="replace-with-a-long-random-string"

# Where the frontend is served from — used to build magic-link URLs and for CORS.
APP_BASE_URL="http://localhost:5173"

MAIL_FROM="no-reply@spearhead.example"
SPEARHEAD_TEAM_EMAIL="servicing@spearhead.example"

# SMTP — works with AWS SES SMTP interface or SendGrid's SMTP relay.
# Leave blank during development: emails are logged to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
